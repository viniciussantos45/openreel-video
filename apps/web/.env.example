# PostHog Analytics (optional)
# Get your keys at https://posthog.com
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=

# OpenReel Cloud URL (required for file-sharing feature in production)
# Point this to your own Cloudflare Worker or compatible backend.
# Leave empty to disable the share feature.
# Example: https://openreel-cloud.<your-account>.workers.dev
VITE_PUBLIC_CLOUD_URL=

# FFmpeg WASM base URL (optional, for self-hosting the FFmpeg core files)
# By default the app loads ffmpeg-core.wasm from unpkg.com.
# To serve the files yourself:
#   1. Copy node_modules/@ffmpeg/core(-mt)/dist/esm/* to public/ffmpeg-core/
#      (run this from the apps/web directory)
#   2. Set this variable to /ffmpeg-core
# For multi-threaded mode use the @ffmpeg/core-mt files instead.
VITE_FFMPEG_CORE_BASE_URL=
